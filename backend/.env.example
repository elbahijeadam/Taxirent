PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/taxirent

# JWT
JWT_SECRET=taxirent-b2b-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Stripe (obtenir sur dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email via Resend (obtenir sur resend.com — domaine vérifié requis en production)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Taxirent <noreply@taxirent.fr>

# URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000

# Notifications admin (email qui reçoit les alertes réservations)
ADMIN_EMAIL=admin@taxirent.fr

# File upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Twilio SMS (optionnel — si absent, vérification téléphone auto-validée)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1your_twilio_number
