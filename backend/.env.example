PORT=5000
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/taxirent

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Stripe (obtenir sur dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Swikly (dépôt de garantie)
SWIKLY_API_KEY=your_swikly_api_key

# Email via Resend (obtenir sur resend.com — domaine vérifié requis)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Taxirent <noreply@taxirent.fr>

# URLs
FRONTEND_URL=https://taxirent.fr
API_URL=https://your-railway-app.railway.app

# Compte admin principal (créé automatiquement au 1er démarrage)
ADMIN_EMAIL=admin@taxirent.fr
ADMIN_PASSWORD=change-this-secure-password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Taxirent
ADMIN_PHONE=

# Compte admin secondaire (optionnel)
ADMIN2_EMAIL=
ADMIN2_PASSWORD=
ADMIN2_FIRST_NAME=
ADMIN2_LAST_NAME=

# Dev uniquement — NE JAMAIS mettre à true en production
# EXPOSE_DEV_OTP=true

# Cloudflare R2 / S3 (stockage documents)
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_r2_access_key
S3_SECRET_ACCESS_KEY=your_r2_secret_key
S3_BUCKET=taxirent-documents
S3_REGION=auto
S3_PUBLIC_URL=https://documents.taxirent.fr

# File upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Twilio SMS (optionnel — si absent, vérification téléphone auto-validée)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1your_twilio_number
